TZ=Asia/Shanghai
SITE_URL=https://your-domain.example.com

# Pushplus user token or message token.
# Docs: https://www.pushplus.plus/doc/guide/api.html
PUSHPLUS_TOKEN=
PUSHPLUS_CHANNEL=wechat
PUSHPLUS_TOPIC=

# Optional. If empty, the assistant uses local scoring and rule-based summaries.
# Any OpenAI-compatible chat completion endpoint can be used.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Tuning.
MAX_ARTICLES=36
PER_CATEGORY_LIMIT=4
GDelt_TIMESPAN=24h
MIN_SCORE=34
GDELT_QUERY_DELAY_MS=4200
